OPENAI_API_KEY=your-openai-api-key-here

# Model tiering — cheap/fast model for per-namespace triage, full model for synthesis
OPENAI_TRIAGE_MODEL=gpt-4o-mini
OPENAI_SYNTHESIS_MODEL=gpt-4o
# Legacy: OPENAI_MODEL sets both if tiered models aren't specified
# OPENAI_MODEL=gpt-4o

# Optional: custom base URL for OpenAI-compatible APIs
# OPENAI_BASE_URL=https://api.openai.com/v1

# PostgreSQL
POSTGRES_USER=bundlescope
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=bundlescope
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://bundlescope:change-me-in-production@postgres:5432/bundlescope

# Redis Cache
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Rate Limiting
# RATE_LIMIT_UPLOAD=10/minute
# RATE_LIMIT_CHAT=20/minute
# RATE_LIMIT_ANALYSIS=30/minute

# Production
# BUNDLESCOPE_ENV=production
# CORS_ORIGINS=https://your-domain.com
