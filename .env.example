OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
# Optional: set a custom base URL for OpenAI-compatible APIs
# OPENAI_BASE_URL=https://api.openai.com/v1

# PostgreSQL
POSTGRES_USER=bundlescope
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=bundlescope
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://bundlescope:change-me-in-production@postgres:5432/bundlescope

# Redis Cache
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
